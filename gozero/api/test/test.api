syntax = "v2"

@server (
	group:      test
	tags:       test
	prefix:     /test
	middleware: UserContextMiddleware,RecoveryMiddleware
)
service App {
	@doc (
		summary:     "测试GoZero服务"
		description: "验证GoZero服务是否正常运行"
	)
	@handler TestGoZeroHandler
	get /gozero returns (TestGoZeroResp)
}

type (
	TestGoZeroResp {
		Data string `json:"data"`
	}
)

