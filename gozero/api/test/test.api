syntax = "v2"

@server (
	group:      test
	tags:       test
	prefix:     /api_gozero
	middleware: UserContextMiddleware,RecoveryMiddleware
)
service App {
	@doc (
		summary:     "测试GoZero服务"
		description: "验证GoZero服务是否正常运行"
	)
	@handler TestGoZeroHandler
	get /gozero returns (TestGoZeroResp)

	@doc (
		summary:     "调用Spring的测试"
		description: "输出欢迎信息"
	)
	@handler TestSpringHandler
	get /spring returns (TestSpringResp)

	@doc (
		summary:     "调用NestJS的测试"
		description: "输出欢迎信息"
	)
	@handler TestNestJSHandler
	get /nestjs returns (TestNestJSResp)

	@doc (
		summary:     "调用FastAPI的测试"
		description: "输出欢迎信息"
	)
	@handler TestFastAPIHandler
	get /fastapi returns (TestFastAPIResp)
}

@server (
	group:      test
	tags:       test
	prefix:     /api_gozero
	middleware: UserContextMiddleware,RecoveryMiddleware,InternalServiceMiddleware
)
service App {
	@doc (
		summary:     "调用同步ES的测试"
		description: "查看是否同步成功"
	)
	@handler SyncESHandler
	post /syncer (SyncESReq) returns (SyncESResp)

	@doc (
		summary:     "手动触发文章向量同步"
		description: "从 pgvector 读取 chunk 向量均值, 写入 ES embedding_vector 字段"
	)
	@handler SyncEmbeddingHandler
	post /syncer/embedding (SyncEmbeddingReq) returns (SyncEmbeddingResp)

	@doc (
		summary:     "手动触发表谱特征缓存同步"
		description: "从 Neo4j 读取活跃用户图谱特征, 写入 Redis user_graph:{id}"
	)
	@handler SyncGraphCacheHandler
	post /syncer/graph-cache (SyncGraphCacheReq) returns (SyncGraphCacheResp)
}

type (
	SyncESReq          {}
	SyncESResp         {}
	SyncEmbeddingReq   {}
	SyncEmbeddingResp  {}
	SyncGraphCacheReq  {}
	SyncGraphCacheResp {}
	TestGoZeroResp {
		Data string `json:"data"`
	}
	TestSpringResp {
		Data string `json:"data"`
	}
	TestNestJSResp {
		Data string `json:"data"`
	}
	TestFastAPIResp {
		Data string `json:"data"`
	}
)

