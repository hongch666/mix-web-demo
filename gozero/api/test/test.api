syntax = "v2"

@server (
	group:  test
	tags:   test
	prefix: /api_gozero
)
service App {
	@doc (
		summary:     "测试GoZero服务"
		description: "验证GoZero服务是否正常运行"
	)
	@handler TestGoZeroHandler
	get /gozero returns (TestGoZeroResp)

	@doc (
		summary:     "调用Spring的测试"
		description: "输出欢迎信息"
	)
	@handler TestSpringHandler
	get /spring returns (TestSpringResp)

	@doc (
		summary:     "调用NestJS的测试"
		description: "输出欢迎信息"
	)
	@handler TestNestJSHandler
	get /nestjs returns (TestNestJSResp)

	@doc (
		summary:     "调用FastAPI的测试"
		description: "输出欢迎信息"
	)
	@handler TestFastAPIHandler
	get /fastapi returns (TestFastAPIResp)
}

@server (
	group:      test
	tags:       test
	prefix:     /api_gozero
	middleware: InternalServiceMiddleware
)
service App {
	@doc (
		summary:     "调用同步ES的测试"
		description: "查看是否同步成功"
	)
	@handler SyncESHandler
	post /syncer (SyncESReq) returns (SyncESResp)
}

type (
	SyncESReq  {}
	TestGoZeroResp {
		Data string `json:"data"`
	}
	TestSpringResp {
		Data string `json:"data"`
	}
	TestNestJSResp {
		Data string `json:"data"`
	}
	TestFastAPIResp {
		Data string `json:"data"`
	}
	SyncESResp  {}
)

