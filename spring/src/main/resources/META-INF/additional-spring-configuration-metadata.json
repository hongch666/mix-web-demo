{
  "properties": [
    {
      "name": "jwt.secret",
      "type": "java.lang.String",
      "description": "JWT 签名密钥"
    },
    {
      "name": "jwt.access-expiration",
      "type": "java.lang.String",
      "description": "Access Token 过期时间（毫秒），默认 15 分钟"
    },
    {
      "name": "jwt.refresh-expiration",
      "type": "java.lang.String",
      "description": "Refresh Token 过期时间（毫秒），默认 7 天"
    },
    {
      "name": "internal-token.secret",
      "type": "java.lang.String",
      "description": "内部服务令牌密钥"
    },
    {
      "name": "internal-token.expiration",
      "type": "java.lang.String",
      "description": "内部服务令牌过期时间（毫秒）"
    },
    {
      "name": "server.mode",
      "type": "java.lang.String",
      "description": "服务运行模式"
    },
    {
      "name": "user.default-password",
      "type": "java.lang.String",
      "description": "默认用户密码"
    },
    {
      "name": "user.reset-password",
      "type": "java.lang.String",
      "description": "重置用户密码"
    }
  ]
}
