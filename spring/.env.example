# Spring 服务配置
SERVER_ADDRESS=0.0.0.0
SERVER_MODE=dev
SERVER_PORT=8081

# Tomcat 配置
TOMCAT_THREADS_MAX=25
TOMCAT_ACCEPT_COUNT=25
TOMCAT_MAX_CONNECTIONS=100

# Feign 远程调用超时配置（毫秒）
FEIGN_CONNECT_TIMEOUT=2000
FEIGN_READ_TIMEOUT=3000

# MySQL 配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=demo
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# MySQL HikariCP 连接池配置
DB_POOL_MAX=20
DB_POOL_MIN_IDLE=5
DB_POOL_TIMEOUT=30000
DB_POOL_IDLE_TIMEOUT=600000
DB_POOL_MAX_LIFETIME=1800000
DB_POOL_LEAK_DETECTION_THRESHOLD=60000

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
# REDIS_USERNAME=
# REDIS_PASSWORD=
REDIS_POOL_MAX_ACTIVE=10
REDIS_POOL_MAX_IDLE=5
REDIS_POOL_MIN_IDLE=1
REDIS_TIMEOUT=3000

# RabbitMQ 配置
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_rabbitmq_username
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_VHOST=test

# 邮件配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password_or_token

# 日志配置
LOGGING_PATH=../logs/spring

# JWT 配置
JWT_SECRET=your_jwt_secret
JWT_EXPIRATION=86400000
INTERNAL_TOKEN_SECRET=your_internal_token_secret
INTERNAL_TOKEN_EXPIRATION=60000

# Nacos 配置
NACOS_SERVER=127.0.0.1:8848
NACOS_NAMESPACE=public
NACOS_GROUP_NAME=DEFAULT_GROUP
