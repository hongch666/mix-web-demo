# Spring 服务配置
SERVER_ADDRESS=0.0.0.0
SERVER_MODE=dev
SERVER_PORT=8081

# Feign 远程调用超时配置（毫秒）
FEIGN_CONNECT_TIMEOUT=2000
FEIGN_READ_TIMEOUT=3000

# MySQL 配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=demo
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
# REDIS_USERNAME=
# REDIS_PASSWORD=

# RabbitMQ 配置
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_rabbitmq_username
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_VHOST=test

# 日志配置
LOGGING_PATH=../logs/spring

# JWT 配置
JWT_SECRET=your_jwt_secret
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000
INTERNAL_TOKEN_SECRET=your_internal_token_secret
INTERNAL_TOKEN_EXPIRATION=60000

# 用户默认密码配置
USER_DEFAULT_PASSWORD=your_default_password
USER_RESET_PASSWORD=your_reset_password

# Nacos 配置
NACOS_SERVER=127.0.0.1:8848
NACOS_NAMESPACE=public
NACOS_GROUP_NAME=DEFAULT_GROUP
