# .env 环境变量配置文件示例
# 复制此文件为 .env 并根据需要修改对应的值
# 此文件不应提交到版本控制系统中

# 服务器相关配置
SERVER_PORT=8888
SERVER_SERVLET_CONTEXT_PATH=/

# Redis相关配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT相关配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=86400

# 网关路由相关配置
GATEWAY_ROUTE_USER_URL=http://localhost:8080
GATEWAY_ROUTE_ADMIN_URL=http://localhost:8081
GATEWAY_ROUTE_CHAT_URL=http://localhost:8082

# 日志级别
LOG_LEVEL=INFO

# 其他自定义配置
APP_NAME=gateway
APP_VERSION=1.0.0
