#!/bin/bash

# 脚本说明：
# 这是根目录下的便捷启动脚本，用于快速启动项目

WORKDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$WORKDIR/scripts"

# 确保scripts目录存在
if [ ! -d "$SCRIPTS_DIR" ]; then
    echo "Error: scripts directory not found at $SCRIPTS_DIR"
    exit 1
fi

# 显示帮助信息
show_help() {
    echo "================================"
    echo "Mix Web Demo - Service Launcher"
    echo "================================"
    echo ""
    echo "Usage: ./mix <COMMAND> [SERVICE_NAME] [SERVICE_NAME] ..."
    echo ""
    echo "Development Commands (开发模式):"
    echo "  multi                    - Run all services in tmux with split panes"
    echo "  seq [OPTIONS]            - Run all services in tmux (sequential window mode)"
    echo "  stop                     - Stop all tmux sessions"
    echo ""
    echo "Seq Options (用于 seq 命令的可选项):"
    echo "  -i, --interactive        - 进入交互式选择模式"
    echo "  --java-build TOOL        - Java 构建工具: gradle(默认)|maven"
    echo "  --node-runtime TOOL      - Node.js 运行时: bun(默认)|npm"
    echo "  --python-runtime TOOL    - Python 运行时: uv(默认)|python"
    echo ""
    echo "Seq Examples:"
    echo "  ./mix seq                     # 使用默认配置 (gradle+bun+uv)"
    echo "  ./mix seq -i                  # 交互式选择"
    echo "  ./mix seq --java-build maven --node-runtime npm"
    echo ""
    echo "Build & Deploy Commands (编译部署):"
    echo "  build                    - Build all services to dist/"
    echo "  start [services...]      - Start built services (or all if not specified)"
    echo "  stop-dist [services...]  - Stop built services (or all if not specified)"
    echo "  restart [services...]    - Restart built services (or all if not specified)"
    echo "  status [services...]     - Check status of services (or all if not specified)"
    echo "  logs <service>           - View latest logs of a specific service"
    echo ""
    echo "Docker Commands (Docker 容器管理):"
    echo "  docker [command]         - Manage Docker containers"
    echo "    up [services...]       - Build and run containers (or all if not specified)"
    echo "    start [services...]    - Start containers from existing images only"
    echo "    build [services...]    - Build images only"
    echo "    push [services...]     - Push built images to remote registry"
    echo "    status                 - Show container status"
    echo "    logs <service>         - View container logs"
    echo "    stop                   - Stop all containers"
    echo "    delete                 - Delete all containers"
    echo ""
    echo "Base Service Commands (基础中间件容器):"
    echo "  docker-services [command] - Manage MySQL/PostgreSQL/Redis/MongoDB/ES/Nacos/RabbitMQ"
    echo "    up                     - Create all base service containers"
    echo "    status                 - Show base container status"
    echo "    logs <service>         - View base container logs"
    echo "    stop                   - Stop all base containers"
    echo "    delete                 - Delete all base containers"
    echo "    help                   - Show base container help"
    echo ""
    echo "Docker Compose Commands (容器编排):"
    echo "  compose [command]        - Manage Docker Compose stack"
    echo "    up                     - 通过 docker-compose 构建并启动服务"
    echo "    down                   - 停止并删除 docker-compose 服务及卷"
    echo "    status                 - 查看 docker-compose 服务状态 (docker-compose ps)"
    echo "    logs <service>         - 查看指定服务日志 (docker-compose logs -f <service>)"
    echo "    help                   - 显示 docker-compose 帮助"
    echo ""
    echo "Setup Commands (初始化):"
    echo "  setup                    - Initialize environment and install dependencies"
    echo "  swag                     - Generate Swagger API documentation"
    echo "  goctl-api [args...]      - Generate GoZero API code"
    echo "  goctl-orm [args...]      - Generate GoZero ORM code"
    echo ""
    echo "Other:"
    echo "  help                     - Show this help message"
    echo ""
    echo "Service Names (服务名称):"
    echo "  spring                   - Spring Boot 服务"
    echo "  gateway                  - Spring Cloud Gateway 服务"
    echo "  fastapi                  - FastAPI 服务"
    echo "  gozero                   - GoZero 服务"
    echo "  nestjs                   - NestJS 服务"
    echo ""
    echo "Examples (示例):"
    echo "  ./mix setup                    # Initialize environment (first time)"
    echo "  ./mix swag                     # Generate Swagger API documentation"
    echo "  ./mix goctl-api                # Generate GoZero API code"
    echo "  ./mix goctl-orm                # Generate GoZero ORM code"
    echo "  ./mix multi                    # Multi-pane tmux layout (dev)"
    echo "  ./mix seq                      # Sequential window layout (dev, default config)"
    echo "  ./mix seq -i                   # Sequential layout with interactive mode"
    echo "  ./mix seq --java-build maven   # Use Maven for Java services"
    echo "  ./mix seq --node-runtime npm   # Use NPM for Node.js"
    echo "  ./mix seq --python-runtime python  # Use Python for FastAPI"
    echo "  ./mix stop                     # Stop tmux sessions (dev)"
    echo "  ./mix build                    # Build all services"
    echo "  ./mix start                    # Start all built services"
    echo "  ./mix start spring gozero      # Start specific services"
    echo "  ./mix restart fastapi          # Restart FastAPI service"
    echo "  ./mix status                   # Check status of all services"
    echo "  ./mix status spring gateway    # Check status of specific services"
    echo "  ./mix logs spring              # View Spring service logs"
    echo "  ./mix stop-dist                # Stop all services"
    echo "  ./mix stop-dist fastapi nestjs # Stop specific services"
    echo "  ./mix docker up                # Build and run all containers"
    echo "  ./mix docker up spring gozero  # Build and run specific containers"
    echo "  ./mix docker start             # Start all containers from existing images"
    echo "  ./mix docker start spring      # Start a specific container only"
    echo "  ./mix docker build             # Build all images only"
    echo "  ./mix docker push --prefix docker.io/yourname # Push all images to remote"
    echo "  ./mix docker push --prefix registry.example.com/team spring gozero"
    echo "  ./mix docker status            # Show container status"
    echo "  ./mix docker logs spring       # View Spring container logs"
    echo "  ./mix docker stop              # Stop all containers"
    echo "  ./mix docker-services up       # Create base middleware containers"
    echo "  ./mix docker-services status   # Show base container status"
    echo "  ./mix docker-services logs mysql # View MySQL container logs"
    echo "  ./mix docker-services stop     # Stop base containers"
    echo ""
    echo "Notes (备注):"
    echo "  - For Windows PowerShell: PowerShell -ExecutionPolicy Bypass -File ./scripts/run.ps1"
    echo "  - Direct script calls are also supported: ./scripts/run_multi.sh"
    echo "  - Use 'logs' command with exactly one service name"
    echo ""
}

# 解析命令参数
COMMAND=${1:-help}

case $COMMAND in
    setup)
        echo "Initializing environment and installing dependencies..."
        bash "$SCRIPTS_DIR/setup.sh"
        ;;
    swag)
        echo "Generating Swagger API documentation..."
        bash "$SCRIPTS_DIR/swag-init.sh"
        ;;
    goctl-api)
        echo "Generating GoZero API code..."
        bash "$SCRIPTS_DIR/goctl-api-init.sh" "${@:2}"
        ;;
    goctl-orm)
        echo "Generating GoZero ORM code..."
        bash "$SCRIPTS_DIR/goctl-orm-init.sh" "${@:2}"
        ;;
    multi)
        echo "Starting services in multi-pane layout..."
        bash "$SCRIPTS_DIR/run_multi.sh"
        ;;
    seq)
        echo "Starting services in sequential window layout..."
        # 将所有额外参数传递给 run.sh
        bash "$SCRIPTS_DIR/run.sh" "${@:2}"
        ;;
    stop)
        echo "Stopping all tmux sessions..."
        bash "$SCRIPTS_DIR/stop.sh"
        ;;
    build)
        echo "Building all services..."
        bash "$SCRIPTS_DIR/build.sh"
        ;;
    start)
        if [ $# -le 1 ]; then
            echo "Starting all built services..."
            bash "$SCRIPTS_DIR/dist-control.sh" start
        else
            echo "Starting specified services: ${@:2}"
            bash "$SCRIPTS_DIR/dist-control.sh" start "${@:2}"
        fi
        ;;
    stop-dist)
        if [ $# -le 1 ]; then
            echo "Stopping all built services..."
            bash "$SCRIPTS_DIR/dist-control.sh" stop
        else
            echo "Stopping specified services: ${@:2}"
            bash "$SCRIPTS_DIR/dist-control.sh" stop "${@:2}"
        fi
        ;;
    restart)
        if [ $# -le 1 ]; then
            echo "Restarting all built services..."
            bash "$SCRIPTS_DIR/dist-control.sh" restart
        else
            echo "Restarting specified services: ${@:2}"
            bash "$SCRIPTS_DIR/dist-control.sh" restart "${@:2}"
        fi
        ;;
    status)
        if [ $# -le 1 ]; then
            echo "Checking all services status..."
            bash "$SCRIPTS_DIR/dist-control.sh" status
        else
            echo "Checking specified services status: ${@:2}"
            bash "$SCRIPTS_DIR/dist-control.sh" status "${@:2}"
        fi
        ;;
    logs)
        if [ $# -le 1 ]; then
            echo "Error: 'logs' command requires a service name"
            echo "Usage: ./mix logs <service_name>"
            echo ""
            echo "Example: ./mix logs spring"
            exit 1
        elif [ $# -gt 2 ]; then
            echo "Error: 'logs' command only accepts one service name"
            exit 1
        else
            echo "Viewing logs for service: $2"
            bash "$SCRIPTS_DIR/dist-control.sh" logs "$2"
        fi
        ;;
    docker)
        if [ $# -lt 2 ]; then
            # 默认执行up命令
            echo "Building and running all Docker containers..."
            bash "$SCRIPTS_DIR/build_and_run_services.sh"
        else
            case $2 in
                up)
                    if [ $# -le 2 ]; then
                        echo "Building and running all Docker containers..."
                        bash "$SCRIPTS_DIR/build_and_run_services.sh"
                    else
                        echo "Building and running specified services: ${@:3}"
                        bash "$SCRIPTS_DIR/build_and_run_services.sh" "${@:3}"
                    fi
                    ;;
                start)
                    if [ $# -le 2 ]; then
                        echo "Starting all Docker containers from existing images..."
                        bash "$SCRIPTS_DIR/build_and_run_services.sh" --start-only
                    else
                        echo "Starting specified containers from existing images: ${@:3}"
                        bash "$SCRIPTS_DIR/build_and_run_services.sh" --start-only "${@:3}"
                    fi
                    ;;
                build)
                    if [ $# -le 2 ]; then
                        echo "Building all Docker images..."
                        bash "$SCRIPTS_DIR/build_and_run_services.sh" --build-only
                    else
                        echo "Building specified images: ${@:3}"
                        bash "$SCRIPTS_DIR/build_and_run_services.sh" --build-only "${@:3}"
                    fi
                    ;;
                push)
                    if [ $# -le 2 ]; then
                        echo "Pushing all Docker images..."
                    else
                        echo "Pushing specified images: ${@:3}"
                    fi
                    bash "$SCRIPTS_DIR/docker-push-images.sh" "${@:3}"
                    ;;
                status)
                    echo "Showing Docker container status..."
                    bash "$SCRIPTS_DIR/build_and_run_services.sh" --status
                    ;;
                logs)
                    if [ $# -le 2 ]; then
                        echo "Error: 'docker logs' requires a service name"
                        exit 1
                    else
                        docker logs -f "mix-$3-container"
                    fi
                    ;;
                stop)
                    echo "Stopping all Docker containers..."
                    bash "$SCRIPTS_DIR/build_and_run_services.sh" --clean
                    ;;
                delete)
                    echo "Deleting all Docker containers..."
                    bash "$SCRIPTS_DIR/build_and_run_services.sh" --clean
                    ;;
                *)
                    echo "Unknown docker command: $2"
                    exit 1
                    ;;
            esac
        fi
        ;;
    docker-services)
        if [ $# -lt 2 ]; then
            echo "Creating all base service containers..."
            bash "$SCRIPTS_DIR/docker-services.sh" up
        else
            echo "Executing base service command: ${@:2}"
            bash "$SCRIPTS_DIR/docker-services.sh" "${@:2}"
        fi
        ;;
    compose)
        if [ $# -lt 2 ]; then
            echo "用法: ./mix compose <up|down|status|logs> [service]"
            exit 1
        fi

        # 查找可用的 compose 命令
        if command -v docker-compose >/dev/null 2>&1; then
            COMPOSE_CMD="docker-compose"
        elif command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
            COMPOSE_CMD="docker compose"
        else
            echo "Error: docker-compose 或 Docker Compose CLI 未安装"
            exit 1
        fi

        case $2 in
            up)
                bash "$SCRIPTS_DIR/docker-compose-up.sh"
                ;;
            down)
                bash "$SCRIPTS_DIR/docker-compose-down.sh"
                ;;
            status)
                $COMPOSE_CMD -f "$WORKDIR/docker-compose.yml" ps
                ;;
            logs)
                if [ $# -le 2 ]; then
                    echo "Error: compose logs requires a service name"
                    exit 1
                fi
                $COMPOSE_CMD -f "$WORKDIR/docker-compose.yml" logs -f "$3"
                ;;
            help)
                echo "docker-compose help: 使用 up/down/status/logs"
                ;;
            *)
                echo "Unknown compose command: $2"
                exit 1
                ;;
        esac
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: $COMMAND"
        echo ""
        show_help
        exit 1
        ;;
esac
